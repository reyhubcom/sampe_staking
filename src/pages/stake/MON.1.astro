        href: 'https://atomicwallet.io/',
        icon: 'tabler:link',
      },
       {
        variant: 'secondary',
        target: '',
        text: 'Staking',
        href: '/monad/mon.2',
        icon: 'tabler:circle-arrow-up-right',
      },
       
    ]}

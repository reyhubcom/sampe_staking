    src="https://cdn.lordicon.com/gfpplxaf.json"
    trigger="hover"
    stroke="light"
    colors="primary:#ffffff,secondary:#8930e8,tertiary:#9cf4a7,quaternary:#ffffff,quinary:#3583ff"
    style="width:100%;height:500px">
</lord-icon>
    </Fragment>

    <Fragment slot="image">
      
    </Fragment>
  </Hero>

  <!-- Features2 Widget ************** -->

  <Features2
    title="Stake Your Monad, Earn Reward"
    subtitle="Monad staking is the process of locking up MON tokens to secure the high-performance, Proof-of-Stake Monad blockchain. By delegating tokens to validators, users earn rewards—comprising inflationary block rewards and user-paid priority fees—while maintaining self-custody. The system utilizes a delegated Proof-of-Stake (dPoS) model with a top 200 validator set and an unbonding period of roughly 1-2 days."
  >
   
  </Features2>

  <!-- Stats Widget ****************** -->
</Hero>

